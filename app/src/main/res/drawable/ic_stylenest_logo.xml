<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Professional Boutique Logo for StyleNest -->
    <!-- Geometric 'SN' Monogram inside a premium Gold frame -->

    <!-- Outer Frame: Elegant Diamond with rounded corners -->
    <path
        android:pathData="M50,10 L90,50 L50,90 L10,50 Z"
        android:strokeWidth="1.5"
        android:strokeColor="#C5A059"
        android:fillColor="#00000000" />

    <!-- Monogram SN: Minimalist and connected strokes -->
    <!-- 'S' curve merging into 'N' vertical -->
    <path
        android:pathData="M38,42 C38,35 44,32 50,32 C56,32 62,35 62,42 C62,49 38,51 38,58 C38,65 44,68 50,68 C56,68 62,65 62,58"
        android:strokeWidth="4"
        android:strokeColor="#C5A059"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Vertical line to complete 'N' structure -->
    <path
        android:pathData="M50,32 L50,68"
        android:strokeWidth="1.2"
        android:strokeColor="#C5A059"
        android:strokeAlpha="0.6" />

</vector>