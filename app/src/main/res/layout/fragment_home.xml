<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Professional Full-Width Edge-to-Edge Slideshow -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:background="@color/black">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/heroCarousel"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/carouselIndicator"
                android:layout_width="wrap_content"
                android:layout_height="12dp"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="12dp"
                android:background="@android:color/transparent"
                app:tabBackground="@drawable/dot_selector"
                app:tabGravity="center"
                app:tabIndicatorHeight="0dp"
                app:tabMaxWidth="8dp"
                app:tabPaddingStart="4dp"
                app:tabPaddingEnd="4dp" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="MEN'S SELECTION"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <GridLayout
                android:id="@+id/mensGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:layout_marginBottom="24dp">
            </GridLayout>

            <!-- KIDS SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="KIDS SELECTION"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <GridLayout
                android:id="@+id/kidsGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:layout_marginBottom="24dp">
            </GridLayout>

            <!-- SHOES SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="TOP FOOTWEAR"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <GridLayout
                android:id="@+id/shoesGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:layout_marginBottom="24dp">
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="WOMEN'S SELECTION"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <GridLayout
                android:id="@+id/womensGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:layout_marginBottom="24dp">
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="ESSENTIALS"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <GridLayout
                android:id="@+id/essentialsGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alignmentMode="alignMargins"
                android:columnCount="2">
            </GridLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>