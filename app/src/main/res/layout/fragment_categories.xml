<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingHorizontal="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="STYLENEST"
            android:textColor="@color/neon_lime"
            android:textStyle="bold"
            android:textSize="18sp"
            android:letterSpacing="0.05" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:text="NAIROBI STREETWEAR"
            android:textColor="@color/text_grey"
            android:textSize="10sp"
            android:letterSpacing="0.1" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- MENS -->
            <LinearLayout
                android:id="@+id/category_mens"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENTER"
                    android:textColor="@color/neon_lime"
                    android:textSize="10sp"
                    android:letterSpacing="0.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MENS"
                    android:textColor="@color/white"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THE FORGE"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="EXPLORE  →"
                    android:textColor="@color/neon_lime"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" />

            <!-- WOMENS -->
            <LinearLayout
                android:id="@+id/category_womens"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENTER"
                    android:textColor="@color/neon_lime"
                    android:textSize="10sp"
                    android:letterSpacing="0.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WOMENS"
                    android:textColor="@color/white"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THE STUDIO"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="EXPLORE  →"
                    android:textColor="@color/neon_lime"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" />

            <!-- KIDS -->
            <LinearLayout
                android:id="@+id/category_kids"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENTER"
                    android:textColor="@color/neon_lime"
                    android:textSize="10sp"
                    android:letterSpacing="0.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KIDS"
                    android:textColor="@color/white"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MINI DROPS"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="EXPLORE  →"
                    android:textColor="@color/neon_lime"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" />

            <!-- SHOES -->
            <LinearLayout
                android:id="@+id/category_shoes"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENTER"
                    android:textColor="@color/neon_lime"
                    android:textSize="10sp"
                    android:letterSpacing="0.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SHOES"
                    android:textColor="@color/white"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STEP UP"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="EXPLORE  →"
                    android:textColor="@color/neon_lime"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" />

            <!-- ACCESSORIES -->
            <LinearLayout
                android:id="@+id/category_accessories"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENTER"
                    android:textColor="@color/neon_lime"
                    android:textSize="10sp"
                    android:letterSpacing="0.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ESSENTIALS"
                    android:textColor="@color/white"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FINISHING TOUCH"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="EXPLORE  →"
                    android:textColor="@color/neon_lime"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="URBAN STREETWEAR · NAIROBI · EST. 2024"
        android:textColor="@color/text_grey"
        android:textSize="10sp"
        android:letterSpacing="0.1" />

</LinearLayout>