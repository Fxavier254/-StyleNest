<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/carouselImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- Professional Left-Side Gradient Overlay for Readability -->
    <View
        android:id="@+id/textOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/carousel_overlay_gradient"
        android:visibility="gone" />

    <!-- Text positioned on the left side, vertically centered, with restricted width -->
    <LinearLayout
        android:id="@+id/textContainer"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/carouselTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:shadowColor="#CC000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4" />

        <TextView
            android:id="@+id/carouselPromo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:alpha="0.95"
            android:shadowColor="#CC000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/shopNowButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="EXPLORE"
            android:textColor="@color/black"
            app:backgroundTint="@color/neon_lime"
            app:cornerRadius="2dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="24dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="40dp" />
    </LinearLayout>
</FrameLayout>